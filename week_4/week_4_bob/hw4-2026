\section*{Exercise 1}

We gebruiken de constanten:
\[
s = \text{Stu}, \qquad j = \text{Joey}, \qquad m = \text{Michael}.
\]

Verder gebruiken we de volgende predicaten:
\[
\begin{array}{ll}
Person(x) & x \text{ is een persoon},\\
Butterfly(x) & x \text{ is een vlinder},\\
Love(x,y) & x \text{ houdt van } y,\\
Like(x,y) & x \text{ vindt } y \text{ leuk},\\
Greet(x,y) & x \text{ groet } y,\\
Cough(x) & x \text{ hoest},\\
Sneeze(x) & x \text{ niest},\\
Swim(x) & x \text{ zwemt}.
\end{array}
\]

\subsection*{(a) Stu loves a butterfly who loves him}

Er is een vlinder waar Stu van houdt, en die vlinder houdt ook van Stu.

\[
\exists x\bigl(Butterfly(x) \land Love(s,x) \land Love(x,s)\bigr)
\]

\subsection*{(b) Stu likes somebody and somebody likes Joey}

Er bestaat een persoon die Stu leuk vindt, en er bestaat een persoon die Joey leuk vindt.

\[
\exists x\bigl(Person(x) \land Like(s,x)\bigr)
\land
\exists y\bigl(Person(y) \land Like(y,j)\bigr)
\]

\subsection*{(c) Nobody greets Michael}

Er bestaat geen persoon die Michael groet.

\[
\neg \exists x\bigl(Person(x) \land Greet(x,m)\bigr)
\]

Equivalent:

\[
\forall x\bigl(Person(x) \rightarrow \neg Greet(x,m)\bigr)
\]

\subsection*{(d) Nobody coughs or sneezes}

Geen enkel persoon hoest of niest.

\[
\neg \exists x\bigl(Person(x) \land (Cough(x) \lor Sneeze(x))\bigr)
\]

Equivalent:

\[
\forall x\bigl(Person(x) \rightarrow (\neg Cough(x) \land \neg Sneeze(x))\bigr)
\]

\subsection*{(e) Somebody coughs and sneezes}

Er bestaat een persoon die zowel hoest als niest.

\[
\exists x\bigl(Person(x) \land Cough(x) \land Sneeze(x)\bigr)
\]

\subsection*{(f) Only one butterfly swims}

Er is precies \'{e}\'{e}n vlinder die zwemt.

\[
\exists x\Bigl(
Butterfly(x)
\land Swim(x)
\land
\forall y\bigl((Butterfly(y) \land Swim(y)) \rightarrow y=x\bigr)
\Bigr)
\]

Hier wordt ``only one'' vertaald met kwantoren en gelijkheid, niet met een apart predicaat.

