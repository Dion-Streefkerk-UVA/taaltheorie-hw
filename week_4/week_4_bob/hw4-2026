\section*{Exercise 3b.1}

\subsection*{Sentence: John plays a song}

De logische representatie is:

\[
\exists x\bigl(Song(x) \land Play(j,x)\bigr)
\]

\subsection*{Parse tree}

\begin{center}
\begin{forest}
for tree={
    draw,
    rounded corners,
    align=center,
    l sep=12mm,
    s sep=8mm
}
[(8) S
    [(2) NP
        [(1) PN\\John]
    ]
    [(7) VP
        [(3) V\\plays]
        [(6) NP
            [(4) D\\a]
            [(5) N\\song]
        ]
    ]
]
\end{forest}
\end{center}

\subsection*{Semantische opbouw}

\subsubsection*{(1) PN: John}
\[\lam{Q}(Q\app j)\]

\subsubsection*{(2) NP: John}
\[\lam{Q}(Q\app j)\]

\subsubsection*{(3) V: plays}
\[\lam{O}\lam{z}O\app(\lam{y}Play(z,y))\]

\subsubsection*{(4) D: a}
\[\lam{P}\lam{Q}\exists x(P\app x \land Q\app x)\]

\subsubsection*{(5) N: song}
\[\lam{w}Song(w)\]

\subsubsection*{(6) NP: a song}

Voor \(\beta\)-conversie:
\[
(\lam{P}\lam{Q}\exists x(P\app x \land Q\app x))
\app
(\lam{w}Song(w))
\]

Na \(\beta\)-conversie:
\[
\lam{Q}\exists x((\lam{w}Song(w))\app x \land Q\app x)
\]
\[
\lam{Q}\exists x(Song(x) \land Q\app x)
\]

Dus:
\[
\sem{a\ song}=\lam{Q}\exists x(Song(x) \land Q\app x)
\]

\subsubsection*{(7) VP: plays a song}

Voor \(\beta\)-conversie:
\[
(\lam{O}\lam{z}O\app(\lam{y}Play(z,y)))
\app
(\lam{Q}\exists x(Song(x) \land Q\app x))
\]

Na \(\beta\)-conversie:
\[
\lam{z}(\lam{Q}\exists x(Song(x) \land Q\app x))
\app
(\lam{y}Play(z,y))
\]
\[
\lam{z}\exists x(Song(x) \land (\lam{y}Play(z,y))\app x)
\]
\[
\lam{z}\exists x(Song(x) \land Play(z,x))
\]

Dus:
\[
\sem{plays\ a\ song}=\lam{z}\exists x(Song(x) \land Play(z,x))
\]

\subsubsection*{(8) S: John plays a song}

Voor \(\beta\)-conversie:
\[
(\lam{Q}(Q\app j))
\app
(\lam{z}\exists x(Song(x) \land Play(z,x)))
\]

Na \(\beta\)-conversie:
\[
(\lam{z}\exists x(Song(x) \land Play(z,x)))\app j
\]
\[
\exists x(Song(x) \land Play(j,x))
\]

Eindantwoord:
\[
\boxed{\exists x(Song(x) \land Play(j,x))}
\]

