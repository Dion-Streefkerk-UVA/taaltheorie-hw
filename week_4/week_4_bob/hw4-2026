\section*{Exercise 3b.2}

\subsection*{Sentence: All musicians love a song}

De compositional semantics van deze grammatica geeft de volgende lezing:

\[
\forall x\bigl(Musician(x) \rightarrow \exists y(Song(y) \land Love(x,y))\bigr)
\]

Betekenis: iedere muzikant houdt van minstens \'{e}\'{e}n liedje. Het liedje mag per muzikant verschillen.

\subsection*{Parse tree}

\begin{center}
\begin{forest}
for tree={
    draw,
    rounded corners,
    align=center,
    l sep=12mm,
    s sep=8mm
}
[(9) S
    [(3) NP
        [(1) D\\all]
        [(2) N\\musicians]
    ]
    [(8) VP
        [(4) V\\love]
        [(7) NP
            [(5) D\\a]
            [(6) N\\song]
        ]
    ]
]
\end{forest}
\end{center}

\subsection*{Semantische opbouw}

\subsubsection*{(1) D: all}
\[\lam{P}\lam{Q}\forall x(P\app x \rightarrow Q\app x)\]

\subsubsection*{(2) N: musicians}
\[\lam{u}Musician(u)\]

\subsubsection*{(3) NP: all musicians}

Voor \(\beta\)-conversie:
\[
(\lam{P}\lam{Q}\forall x(P\app x \rightarrow Q\app x))
\app
(\lam{u}Musician(u))
\]

Na \(\beta\)-conversie:
\[
\lam{Q}\forall x((\lam{u}Musician(u))\app x \rightarrow Q\app x)
\]
\[
\lam{Q}\forall x(Musician(x) \rightarrow Q\app x)
\]

Dus:
\[
\sem{all\ musicians}=\lam{Q}\forall x(Musician(x) \rightarrow Q\app x)
\]

\subsubsection*{(4) V: love}
\[\lam{O}\lam{z}O\app(\lam{y}Love(z,y))\]

\subsubsection*{(5) D: a}
\[\lam{P}\lam{Q}\exists y(P\app y \land Q\app y)\]

\subsubsection*{(6) N: song}
\[\lam{w}Song(w)\]

\subsubsection*{(7) NP: a song}

Voor \(\beta\)-conversie:
\[
(\lam{P}\lam{Q}\exists y(P\app y \land Q\app y))
\app
(\lam{w}Song(w))
\]

Na \(\beta\)-conversie:
\[
\lam{Q}\exists y((\lam{w}Song(w))\app y \land Q\app y)
\]
\[
\lam{Q}\exists y(Song(y) \land Q\app y)
\]

Dus:
\[
\sem{a\ song}=\lam{Q}\exists y(Song(y) \land Q\app y)
\]

\subsubsection*{(8) VP: love a song}

Voor \(\beta\)-conversie:
\[
(\lam{O}\lam{z}O\app(\lam{y}Love(z,y)))
\app
(\lam{Q}\exists y(Song(y) \land Q\app y))
\]

Om variabelenverwarring te vermijden, hernoemen we de gebonden variabele \(y\) in de object-NP naar \(v\):
\[
\lam{Q}\exists v(Song(v) \land Q\app v)
\]

Dan krijgen we:
\[
(\lam{O}\lam{z}O\app(\lam{y}Love(z,y)))
\app
(\lam{Q}\exists v(Song(v) \land Q\app v))
\]

Na \(\beta\)-conversie:
\[
\lam{z}(\lam{Q}\exists v(Song(v) \land Q\app v))
\app
(\lam{y}Love(z,y))
\]
\[
\lam{z}\exists v(Song(v) \land (\lam{y}Love(z,y))\app v)
\]
\[
\lam{z}\exists v(Song(v) \land Love(z,v))
\]

Dus:
\[
\sem{love\ a\ song}=\lam{z}\exists v(Song(v) \land Love(z,v))
\]

\subsubsection*{(9) S: All musicians love a song}

Voor \(\beta\)-conversie:
\[
(\lam{Q}\forall x(Musician(x) \rightarrow Q\app x))
\app
(\lam{z}\exists v(Song(v) \land Love(z,v)))
\]

Na \(\beta\)-conversie:
\[
\forall x\bigl(Musician(x) \rightarrow (\lam{z}\exists v(Song(v) \land Love(z,v)))\app x\bigr)
\]
\[
\forall x\bigl(Musician(x) \rightarrow \exists v(Song(v) \land Love(x,v))\bigr)
\]

Eindantwoord:
\[
\boxed{\forall x\bigl(Musician(x) \rightarrow \exists v(Song(v) \land Love(x,v))\bigr)}
\]

